FROM ubuntu:22.04

RUN apt-get update && \
    apt-get install -y python3 python3-pip gdb && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

RUN pip3 install pwntools

WORKDIR /solve

COPY challenge ./challenge
COPY libc.so.6 ./libc.so.6
COPY exploit_template.py ./exploit_template.py

RUN chmod +x challenge

CMD ["/bin/bash"]