FROM --platform=linux/amd64 ubuntu:22.04

RUN apt-get update && \
    apt-get install -y python3 python3-pip gdb && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

RUN pip3 install pwntools

WORKDIR /solve

COPY challenge.c .
COPY Makefile .
COPY libc.so.6 .
COPY exploit_template.py .

RUN make

CMD ["/bin/bash"]