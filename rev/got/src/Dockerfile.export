FROM ubuntu:22.04 AS build

RUN apt-get update && \
    apt-get install -y gcc && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /build

COPY challenge.c .
COPY Makefile .

RUN gcc -Wall -Wextra -o challenge challenge.c -Wl,-z,relro,-z,lazy && \
    cp /lib/x86_64-linux-gnu/libc.so.6 ./libc.so.6

FROM scratch AS export
COPY --from=build /build/challenge /challenge
COPY --from=build /build/libc.so.6 /libc.so.6